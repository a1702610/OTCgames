# Copy this file to .env.local and set the path to your local medication image library.
# This should point to the 'medications' folder from the shared OneDrive,
# wherever it syncs on your machine. Do NOT include a trailing slash.
#
# Windows example:
IMAGE_LIBRARY_PATH=C:\Users\YourName\OneDrive\OTC Games\medications
#
# Mac example:
# IMAGE_LIBRARY_PATH=/Users/yourname/Library/CloudStorage/OneDrive-Personal/OTC Games/medications
